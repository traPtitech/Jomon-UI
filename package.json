{
  "name": "jomon-ui",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "npm@11.6.1",
  "scripts": {
    "dev": "vite",
    "serve": "vite preview",
    "build": "vue-tsc --build && vite build",
    "build:watch": "vite build --watch",
    "lint": "eslint --fix --cache src scripts vite.config.ts eslint.config.js",
    "lint:nofix": "eslint --cache src scripts vite.config.ts eslint.config.js",
    "lint:ci": "eslint src scripts vite.config.ts eslint.config.js --max-warnings=0",
    "type-check": "vue-tsc --build --noEmit",
    "gen-api": "esno ./scripts/generate-apis.ts",
    "clean": "rimraf src/lib/apis/generated",
    "postinstall": "npm run gen-api",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "axios": "^1.15.0",
    "luxon": "^3.7.2",
    "markdown-it": "^14.1.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vue-toastification": "^2.0.0-rc.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@faker-js/faker": "^10.4.0",
    "@heroicons/vue": "^2.2.0",
    "@openapitools/openapi-generator-cli": "^2.31.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/luxon": "^3.7.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/compiler-sfc": "^3.5.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "axe-core": "^4.11.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.9.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "esno": "^4.8.0",
    "execa": "^9.6.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.5",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rollup-plugin-brotli": "^3.1.0",
    "tailwindcss": "^4.2.2",
    "ts-morph": "^28.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.50.1",
    "vite": "^8.0.5",
    "vue-axe": "^3.1.2",
    "vue-tsc": "^3.2.6"
  },
  "msw": {
    "workerDirectory": "public"
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue,css,md,json,yml}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
